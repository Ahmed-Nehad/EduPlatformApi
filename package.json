{
  "name": "EduPlatform",
  "version": "1.0.0",
  "description": "Educational Platform API",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.ts",
    "start": "node src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "node src/db/seed.ts",
    "test": "cross-env APP_STAGE=test vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "educational-platform",
    "api",
    "nodejs",
    "express",
    "drizzle"
  ],
  "author": "Ahmed Nehad",
  "license": "ISC",
  "overrides": {
    "esbuild": "^0.25.0",
    "tar": "^6.2.1"
  },
  "dependencies": {
    "@epic-web/remember": "^1.1.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "custom-env": "^2.0.6",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "glob": "^13.0.6",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "jose": "^6.0.12",
    "morgan": "^1.10.1",
    "pg": "^8.16.3",
    "rate-limit-redis": "^5.0.0",
    "resend": "^6.16.0",
    "ts-node": "^10.9.2",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.11.5",
    "@types/supertest": "^6.0.2",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "supertest": "^6.3.4",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
